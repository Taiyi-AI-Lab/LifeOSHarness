# LifeOS Platform (lifeostomanyagent)
# Development defaults. Copy to .env and change secrets before any non-local use.
# See SECURITY.md for the pre-release / deployment checklist.
# DATABASE_URL is optional. When unset, LifeOS uses SQLite at
# {LIFEOS_DATA_ROOT}/lifeos.sqlite3. For PostgreSQL, uncomment and replace:
# DATABASE_URL=postgresql+psycopg://lifeos:lifeos@127.0.0.1:5432/lifeos
# REDIS_URL is optional context cache only.
# REDIS_URL=redis://127.0.0.1:6379/0
# Dev-only fallback key. Replace with a long random secret before exposure.
LIFEOS_API_KEY=dev-lifeos-key-change-me
LIFEOS_DATA_ROOT=./data
# 0.0.0.0 is convenient for local/containers; do not expose it directly on a public host.
LIFEOS_HOST=0.0.0.0
LIFEOS_PORT=8000
# rules = deterministic gate, llm = DeepSeek gate with rules fallback, off = always inject.
LIFEOS_INTENT_CLASSIFIER=rules
LIFEOS_INTENT_TIMEOUT_SECONDS=3
# Leave blank to use local rule-based dreams. Never commit a real key.
DEEPSEEK_API_KEY=
DEEPSEEK_DREAM_MODEL=deepseek-v4-pro
DEEPSEEK_DREAM_BASE_URL=https://api.deepseek.com
DEEPSEEK_INTENT_MODEL=deepseek-chat
DEEPSEEK_INTENT_BASE_URL=
